# Deployment template for docker-compose.ghcr*.yaml
# Copy to .env on target host and adjust values.

# Image coordinates
GHCR_OWNER=saveenergy
IMAGE_TAG=edge

# Public routing
PUBLIC_HOST=speed.example.com
SERVER_NAME="Frankfurt 10G"
ALLOWED_ORIGINS=https://speed.example.com

# Server listener and test ports
PORT=8080
BIND_ADDRESS=0.0.0.0
TCP_TEST_PORT=8081
UDP_TEST_PORT=8082

# Traefik integration (docker-compose.ghcr.traefik.yaml)
TRAEFIK_HOST=speed.example.com
TRAEFIK_DASHBOARD_HOST=traefik.example.com
ACME_EMAIL=admin@example.com

# Optional network trust
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=

# Capacity and limits
CAPACITY_GBPS=25
RATE_LIMIT_PER_IP=100
GLOBAL_RATE_LIMIT=1000
MAX_CONCURRENT_TESTS=10
MAX_STREAMS=32
MAX_TEST_DURATION=300s
MAX_CONCURRENT_PER_IP=10
MAX_STORED_RESULTS=10000

# Runtime diagnostics and profiling
PPROF_ENABLED=false
PPROF_ADDR=127.0.0.1:6060
PERF_STATS_INTERVAL=
RUNTIME_METRICS_ENABLED=false
LOG_LEVEL=info

# Optional development asset override
WEB_ROOT=

# Data persistence path inside container
DATA_DIR=/app/data

# TLS configuration
TLS_CERT_FILE=
TLS_KEY_FILE=
TLS_AUTO_GEN=true
