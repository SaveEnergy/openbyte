# Deployment template for docker-compose.ghcr*.yaml
# Copy to .env on target host and adjust values.

# Image coordinates
GHCR_OWNER=saveenergy
IMAGE_TAG=edge

# Public routing
# Reserved compatibility metadata; currently does not affect routing or result URLs.
PUBLIC_HOST=
SERVER_NAME="Frankfurt 10G"
ALLOWED_ORIGINS=https://speed.example.com

# Server listener (bare-metal/systemd runs only — the Docker image listens on
# 8080 internally; change the compose port mapping to expose a different port)
PORT=8080
BIND_ADDRESS=0.0.0.0

# Traefik integration (docker-compose.ghcr.traefik.yaml)
# Host rule for the speed test (include v4/v6 probe subdomains when used).
TRAEFIK_HOST_RULE="Host(`speed.example.com`) || Host(`v4.speed.example.com`) || Host(`v6.speed.example.com`)"
TRAEFIK_DASHBOARD_HOST=traefik.example.com
ACME_EMAIL=admin@example.com
TRAEFIK_TLS_OPTIONS=openbyte-h1@file

# Direct deployments leave proxy trust disabled. The CI-managed Traefik deploy
# overrides both values with the actual Traefik network subnet automatically.
# For a manual reverse-proxy deployment, enable it and list only the proxy subnet(s).
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=

# Capacity and limits
CAPACITY_GBPS=25
RATE_LIMIT_PER_IP=100
GLOBAL_RATE_LIMIT=1000
MAX_TEST_DURATION=300s
MAX_CONCURRENT_PER_IP=64
MAX_STORED_RESULTS=10000

# Runtime diagnostics and profiling
PPROF_ENABLED=false
PPROF_ADDR=127.0.0.1:6060
PERF_STATS_INTERVAL=
RUNTIME_METRICS_ENABLED=false
LOG_LEVEL=info

# Data persistence path inside container
DATA_DIR=/app/data

# Direct TLS is for bare-metal or custom Compose deployments. The provided
# Compose health checks use plain HTTP and do not mount certificate files, so
# leave these disabled when using the bundled Compose files with Traefik.
TLS_CERT_FILE=
TLS_KEY_FILE=
TLS_AUTO_GEN=false
HTTP2_ENABLED=true
