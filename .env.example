# Docker Compose deployment template.
# Copy to .env on target host and adjust values.

# Image coordinates
GHCR_OWNER=saveenergy
IMAGE_TAG=edge

# Public routing
SERVER_NAME="Frankfurt 10G"

# Optional visual branding. Color overrides must be complete dark/light pairs
# in exact #RRGGBB form. The logo path is inside the container; place a PNG or
# JPEG (max 1 MiB) in BRAND_ASSETS_DIR on the host.
BRAND_PRIMARY_COLOR_DARK=
BRAND_PRIMARY_COLOR_LIGHT=
BRAND_SECONDARY_COLOR_DARK=
BRAND_SECONDARY_COLOR_LIGHT=
BRAND_ASSETS_DIR=../branding
BRAND_LOGO_PATH=

# Traefik integration (docker-compose.traefik.yaml)
# Host rule for the speed test (include v4/v6 probe subdomains when used).
TRAEFIK_HOST_RULE="Host(`speed.example.com`) || Host(`v4.speed.example.com`) || Host(`v6.speed.example.com`)"
ACME_EMAIL=admin@example.com
TRAEFIK_TLS_OPTIONS=openbyte-h1@file

# Direct deployments leave proxy trust disabled. The CI-managed Traefik deploy
# overrides both values with the actual Traefik network subnet automatically.
# For a manual reverse-proxy deployment, enable it and list only the proxy subnet(s).
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=

# The binary owns runtime defaults. Add only deliberate server overrides from
# README.md's environment-variable table; bundled Compose forwards supported
# server, branding, proxy, transfer-limit, and result-retention values when set.
