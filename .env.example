# Deployment template for docker-compose.ghcr*.yaml
# Copy to .env on target host and adjust values.

# Image coordinates
GHCR_OWNER=saveenergy
IMAGE_TAG=edge

# Public routing
PUBLIC_HOST=speed.example.com
ALLOWED_ORIGINS=https://speed.example.com

# Server identity
SERVER_ID=openbyte-1
SERVER_NAME=OpenByte Server
SERVER_LOCATION=Unknown
SERVER_REGION=

# Traefik integration (docker-compose.ghcr.traefik.yaml)
TRAEFIK_HOST=speed.example.com
TRAEFIK_DASHBOARD_HOST=traefik.example.com
ACME_EMAIL=admin@example.com

# Optional network trust
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=

# Capacity and limits
CAPACITY_GBPS=25
RATE_LIMIT_PER_IP=100
GLOBAL_RATE_LIMIT=1000
MAX_STORED_RESULTS=10000

# Data persistence path inside container
DATA_DIR=/app/data
